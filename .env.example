# Local development – matches backed_end_schedley default (port 8000)
VITE_APP_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000/api

# “Book demo / Book meeting” URL (Calendly or other) — used in header, footer, and service pages
# VITE_BOOK_MEETING_URL=https://calendly.com/notification-schedley/pipeline-quality-growth-system-quick-walkthrough

# Optional: Groq for landing chatbot
# VITE_GROQ_API_KEY=your_key

# Production (override when deploying)
# VITE_APP_ORIGIN=https://www.schedley.com
# VITE_API_BASE_URL=https://api.schedley.com/api

# Canonical URLs, sitemap, and JSON-LD (no trailing slash). Defaults to https://www.schedley.com
# VITE_PUBLIC_SITE_URL=https://www.schedley.com

